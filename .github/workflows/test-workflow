name: Test workflow

on:
  workflow_dispatch:
  push:
    branches:
      - main

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - name: Print message
        run: |
          echo "Workflow is running!"
          echo "Repository: ${{ github.repository }}"
